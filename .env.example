# Copie este arquivo para .env para uso local (nunca suba o .env para o GitHub)
# No Railway, configure cada linha abaixo como Environment Variable no painel.

# ── Pocket Option ──────────────────────────────────────────
PO_EMAIL=seu_email@gmail.com
PO_PASSWORD=sua_senha
PO_DEMO=false
# SSIDs separados por vírgula (obtenha com python capturar_ssid.py)
PO_SSIDS=SSID1,SSID2

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id

# ── IA DeepSeek ────────────────────────────────────────────
DEEPSEEK_API_KEY=sua_chave_deepseek

# ── Modo de operação ───────────────────────────────────────
# true = simulação (sem ordens reais), false = conta real
SIMULATION_MODE=false
